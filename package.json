  "license": "MIT",
  "homepage": "https://airlabs.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airlabs-co/airlabs-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/airlabs-co/airlabs-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
