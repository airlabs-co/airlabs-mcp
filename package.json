{
  "name": "@airlabs/airlabs-mcp",
  "version": "1.0.0",
  "description": "Official AirLabs API MCP server — real-time flight data, schedules, delays, airports, airlines, fleets and routes as tools for AI assistants.",
  "type": "module",
  "bin": {
    "airlabs-mcp": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "start": "node build/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "airlabs",
